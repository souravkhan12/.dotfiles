  "editor.tokenColorCustomizations": {
    "[Light Modern]": {
      "comments": "#9a9482",
      "strings": "#7a8450",
      "keywords": "#c96442",
      "numbers": "#b88a3e",
      "types": "#5b7a99",
      "functions": "#9a6a8c",
      "variables": "#3d3929",
      "textMateRules": [
        {
          "scope": ["comment", "punctuation.definition.comment"],
          "settings": { "foreground": "#9a9482", "fontStyle": "italic" },
        },
        {
          "scope": ["string", "string.quoted", "string.template"],
          "settings": { "foreground": "#7a8450" },
        },
        {
          "scope": ["constant.numeric", "constant.language"],
          "settings": { "foreground": "#b88a3e" },
        },
        {
          "scope": [
            "keyword",
            "keyword.control",
            "storage.type",
            "storage.modifier",
          ],
          "settings": { "foreground": "#c96442" },
        },
        {
          "scope": [
            "entity.name.function",
            "support.function",
            "meta.function-call",
          ],
          "settings": { "foreground": "#9a6a8c" },
        },
        {
          "scope": [
            "entity.name.type",
            "entity.name.class",
            "support.class",
            "support.type",
          ],
          "settings": { "foreground": "#5b7a99" },
        },
        {
          "scope": ["variable", "variable.other", "variable.parameter"],
          "settings": { "foreground": "#3d3929" },
        },
        {
          "scope": [
            "variable.language",
            "variable.language.this",
            "variable.language.self",
          ],
          "settings": { "foreground": "#9a6a8c", "fontStyle": "italic" },
        },
        {
          "scope": ["entity.other.attribute-name"],
          "settings": { "foreground": "#b88a3e" },
        },
        {
          "scope": ["entity.name.tag", "punctuation.definition.tag"],
          "settings": { "foreground": "#c96442" },
        },
        {
          "scope": ["markup.heading", "markup.bold"],
          "settings": { "foreground": "#c96442", "fontStyle": "bold" },
        },
        { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
        {
          "scope": ["markup.inline.raw", "markup.fenced_code"],
          "settings": { "foreground": "#7a8450" },
        },
        {
          "scope": ["markup.underline.link", "markup.link"],
          "settings": { "foreground": "#5b7a99" },
        },
        {
          "scope": ["punctuation", "meta.brace"],
          "settings": { "foreground": "#6b6657" },
        },
        {
          "scope": ["invalid", "invalid.illegal"],
          "settings": { "foreground": "#c96442" },
        },
      ],
    },
  },
}
